generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

// ── Meal ─────────────────────────────────────────────────────────────────────
// A single meal generated by AI. recipe and prepGuide are stored as JSON strings.

model Meal {
  id          String   @id @default(cuid())
  name        String
  description String?
  // JSON: { ingredients: Ingredient[], steps: string[] }
  recipe      String
  // JSON: { steps: string[], vacuumTips: string[] }
  prepGuide   String
  createdAt   DateTime @default(now())

  ratings         MealRating[]
  weeklyPlanMeals WeeklyPlanMeal[]
}

// ── MealRating ────────────────────────────────────────────────────────────────
// User feedback on a meal. One rating per use (liked/disliked).
// Multiple ratings allowed over time — most recent is used for AI weighting.

model MealRating {
  id        String   @id @default(cuid())
  mealId    String
  meal      Meal     @relation(fields: [mealId], references: [id], onDelete: Cascade)
  rating    String   // 'liked' | 'disliked'
  createdAt DateTime @default(now())
}

// ── IngredientPreference ──────────────────────────────────────────────────────
// Persistent ingredient preferences sent to AI on every generation.

model IngredientPreference {
  id         String   @id @default(cuid())
  ingredient String   @unique
  type       String   // 'blocked' | 'preferred'
  createdAt  DateTime @default(now())
}

// ── WeeklyPlan ────────────────────────────────────────────────────────────────
// One plan per week, keyed to the Monday date of that week.

model WeeklyPlan {
  id          String   @id @default(cuid())
  weekStart   DateTime // Monday 00:00:00 UTC
  createdAt   DateTime @default(now())
  skippedDays String   @default("[]") // JSON array of day names marked as day-off

  meals         WeeklyPlanMeal[]
  shoppingItems ShoppingListItem[]

  @@unique([weekStart])
}

// ── WeeklyPlanMeal ────────────────────────────────────────────────────────────
// Junction between a WeeklyPlan and a Meal, with day assignment.

model WeeklyPlanMeal {
  id        String     @id @default(cuid())
  planId    String
  plan      WeeklyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  mealId    String
  meal      Meal       @relation(fields: [mealId], references: [id])
  dayOfWeek String     // 'Monday' | 'Tuesday' | 'Wednesday' | 'Thursday' | 'Friday'
  servings  Int        @default(6) // 4 family + 2 extra
  locked    Boolean    @default(false) // If true, regenerate skips this day

  @@unique([planId, dayOfWeek])
}

// ── AppSettings ───────────────────────────────────────────────────────────────
// Single-row singleton for app configuration. id is always "singleton".

model AppSettings {
  id              String @id @default("singleton")
  passwordHash    String @default("") // scrypt hash of the app password
  anthropicApiKey String @default("") // user-supplied Anthropic API key
  planDays        String @default("[\"Monday\",\"Tuesday\",\"Wednesday\",\"Thursday\",\"Friday\"]") // JSON array
}

// ── ShoppingListItem ──────────────────────────────────────────────────────────
// Aggregated grocery list for a WeeklyPlan. Amounts are pre-scaled strings.

model ShoppingListItem {
  id       String     @id @default(cuid())
  planId   String
  plan     WeeklyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  item     String
  amount   String
  unit     String
  category String     // 'proteins' | 'produce' | 'dairy' | 'pantry' | 'spices'
  checked  Boolean    @default(false)
  note     String?
}
